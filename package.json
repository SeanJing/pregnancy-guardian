{
  "name": "pregnancy-guardian",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "python3.12 server/app.py",
    "start": "python3.12 server/app.py & vite",
