    "recharts": "^3.8.1",
    "wrangler": "^4.86.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.4",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
